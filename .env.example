# Root env example for local scripts/orchestration.
# Do not put real secrets in this file.

# Optional ROS Dev Center deployment fallback credentials (server-side only).
# Routine add/edit/update/clear belongs in Settings -> ROS Dev Center.
# Required: owner/repo for the repository that runs .github/workflows/playwright-e2e.yml
# RIVERSIDE_OPS_E2E_GITHUB_REPO=your-org/riverside-os
#
# Required: read-only token with minimum GitHub Actions workflow-run/job/log read access.
# Keep this server-side only; never place in client env.
# RIVERSIDE_OPS_E2E_GITHUB_TOKEN=
#
# Optional request timeout in milliseconds (default 8000, bounded 1000..30000).
# RIVERSIDE_OPS_E2E_GITHUB_TIMEOUT_MS=8000

# Legacy fallback GitHub personal access token for DevOps Center (releases, workflows, dispatch).
# Prefer the Settings -> ROS Dev Center GitHub token; the server reads that app-managed token first.
# Requires: repo (read) + workflow (write for dispatch). Server-side only.
# RIVERSIDE_GITHUB_TOKEN=

# ROSIE AI provider selection for diagnostic analysis and chat completions.
# Supported: local_llm, remote_lmstudio, openai, gemini. Legacy ROSIE_PROVIDER_MODE
# and RIVERSIDE_LLAMA_PROVIDER are still mapped for compatibility.
# ROSIE_PROVIDER=local_llm
# ROSIE_FORCE_LOCAL_FOR_SENSITIVE=true
# ROSIE_ALLOW_CLOUD_FOR_SENSITIVE=false
#
# Local Gemma / llama.cpp:
# ROSIE_LOCAL_LLM_BASE_URL=http://127.0.0.1:8080
# RIVERSIDE_LLAMA_UPSTREAM=http://127.0.0.1:8080
#
# Remote LM Studio / LM Link on the work hub:
# ROSIE_PROVIDER=remote_lmstudio
# ROSIE_REMOTE_LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
# ROSIE_REMOTE_LMSTUDIO_MODEL=gemma-4-12B-it-q5_k_m.gguf
# ROSIE_REMOTE_LMSTUDIO_CONTEXT_HINT=65536
#
# Speech provider selection:
# ROSIE_STT_PROVIDER=local
# ROSIE_TTS_PROVIDER=local
#
# Optional deployment fallback for ROSIE provider credentials.
# Routine keys, endpoints, and cloud model names belong in Settings -> ROSIE -> ROSIE Provider Credentials.
# Cloud providers stay server-side only; never place these in client env.
# OPENAI_API_KEY=
# ROSIE_OPENAI_LLM_MODEL=gpt-4.1-mini
# ROSIE_OPENAI_STT_MODEL=gpt-4o-mini-transcribe
# ROSIE_OPENAI_TTS_MODEL=gpt-4o-mini-tts
# ROSIE_OPENAI_TTS_VOICE=alloy
# GEMINI_API_KEY=
# ROSIE_GEMINI_MODEL=gemini-2.5-pro
# ROSIE_GEMINI_STT_MODEL=gemini-2.5-flash
# ROSIE_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# ROSIE_GEMINI_TTS_VOICE=Kore

# Optional: Helcim deployment fallback credentials. Routine setup belongs in Settings -> Helcim.
# Keep the API token out of client env files and browser-visible config.
# HELCIM_API_TOKEN=
# HELCIM_TERMINAL_1_DEVICE_CODE=
# HELCIM_TERMINAL_2_DEVICE_CODE=
# HELCIM_WEBHOOK_SECRET=
# HELCIM_API_BASE_URL=https://api.helcim.com/v2
# Dev only: simulate Helcim terminal approve/decline/cancel without Helcim hardware. Disabled when RIVERSIDE_STRICT_PRODUCTION=true.
# HELCIM_SIMULATOR_ENABLED=false

# --- Production network hardening ---
# Bind address for the Riverside server. Default 0.0.0.0:3000 accepts Tailscale and LAN connections.
# RIVERSIDE_HTTP_BIND=0.0.0.0:3000

# CORS allowlist for browser-facing deployments. REQUIRED when RIVERSIDE_STRICT_PRODUCTION=true.
# List exact Tailscale IPs or MagicDNS hostnames, comma-separated.
# RIVERSIDE_CORS_ORIGINS=http://100.x.y.z:3000,http://store-pc:3000

# Strict production mode. Enforces CORS origin allowlist and credential validation on startup.
# RIVERSIDE_STRICT_PRODUCTION=true

# --- Metabase OSS / Insights docker-compose settings ---
# These are consumed by the root docker-compose.yml when running the free OSS Metabase service.
# METABASE_SITE_URL must match how staff open ROS, including /metabase/.
# METABASE_SITE_URL=http://localhost:5173/metabase/
# METABASE_SITE_NAME=Riverside Insights
# METABASE_JAVA_TIMEZONE=America/New_York
# METABASE_ANON_TRACKING_ENABLED=false
# Native Metabase boot secret. Set before adding databases if you want Metabase to encrypt
# database connection credentials in its own application DB. Keep stable after first use.
# Generate with: openssl rand -base64 32
# MB_ENCRYPTION_SECRET_KEY=
# Public links bypass normal ROS/Metabase login; keep disabled unless an admin intentionally uses public or guest embeds.
# METABASE_ENABLE_PUBLIC_SHARING=false

# --- Vendor Document Import / Import PO-Invoice ---
# Original vendor files are stored outside git here.
# RIVERSIDE_PROCUREMENT_IMPORT_DIR=data/procurement-imports
# RIVERSIDE_PROCUREMENT_IMPORT_MAX_BYTES=26214400

# Local ROSIE/Gemma procurement extractor. When enabled, every supported file type is sent
# to this local endpoint as base64 plus deterministic raw text/table pre-read where available.
# RIVERSIDE_ROSIE_PROCUREMENT_ENABLED=false
# RIVERSIDE_ROSIE_PROCUREMENT_URL=http://127.0.0.1:8765/v1/procurement/extract
# RIVERSIDE_ROSIE_PROCUREMENT_TIMEOUT_MS=20000
# RIVERSIDE_ROSIE_PROCUREMENT_MODEL=gemma-4-E4B-it
