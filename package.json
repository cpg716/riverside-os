{
  "name": "riverside-os",
  "private": true,
  "version": "0.2.1",
  "description": "Root scripts only; app code lives in server/ and client/",
  "scripts": {
    "bump": "node scripts/bump-version.mjs",
    "generate:help": "cd client && npm run generate:help",
    "generate:help:components": "cd client && npm run generate:help:components",
    "generate:help:components:rescan": "cd client && npm run generate:help:components:rescan",
    "generate:help:components:cleanup": "cd client && npm run generate:help:components:cleanup --",
    "check:server": "bash scripts/cargo-server.sh check",
    "dev": "concurrently -n api,ui,bridge -c blue,magenta,green \"npm run dev:server\" \"npm run dev:client:wait\" \"npm run dev:bridge\"",
    "dev:e2e": "bash scripts/e2e-local-stack.sh",
    "dev:server": "bash scripts/dev-server.sh",
    "dev:client:wait": "wait-on -t 600000 tcp:127.0.0.1:3000 && npm run dev:client",
    "dev:client": "cd client && npm run dev",
    "dev:bridge": "wait-on -t 600000 tcp:127.0.0.1:3000 && cd counterpoint-bridge && node index.mjs",
    "lint": "cd client && npm run lint",
    "test:e2e:list": "npm --prefix client run test:e2e -- --list",
    "test:e2e:release": "npm --prefix client run test:e2e -- --workers=1",
    "test:e2e:visual": "cross-env E2E_RUN_VISUAL=1 npm --prefix client run test:e2e -- --workers=1",
    "test:e2e:high-risk": "npm --prefix client run test:e2e -- e2e/high-risk-regressions.spec.ts --workers=1",
    "test:e2e:phase2": "npm --prefix client run test:e2e -- e2e/phase2-finance-and-help-lifecycle.spec.ts --workers=1",
    "test:e2e:tender": "npm --prefix client run test:e2e -- e2e/tender-matrix-contract.spec.ts --workers=1",
    "docker:db": "docker compose up -d"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "shadcn": "^4.2.0",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1"
  }
}
