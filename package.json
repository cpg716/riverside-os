{
  "name": "riverside-os",
  "private": true,
  "version": "0.95.0",
  "description": "Root scripts only; app code lives in server/ and client/",
  "scripts": {
    "bump": "node scripts/bump-version.mjs",
    "check:version": "node scripts/check-version-parity.mjs",
    "check:deployment-release": "node scripts/check-deployment-release.mjs",
    "check:updater-release": "node scripts/verify-updater-release-assets.mjs",
    "check:print-routing": "node scripts/check-print-routing-manifest.mjs",
    "check:reports": "node scripts/check-reports-catalog.mjs",
    "check:search-indexes": "node scripts/check-search-indexes.mjs",
    "check:production-performance": "node scripts/check-production-performance.mjs",
    "check:help-impact": "node scripts/check-help-impact.mjs",
    "check:staff-customer-save-contracts": "node scripts/check-staff-customer-save-contracts.mjs",
    "check:financial-invariants": "node scripts/check-financial-invariants.mjs",
    "check:go-live-blockers": "node scripts/check-go-live-blockers.mjs",
    "check:dirty-migration-rehearsal": "node scripts/check-dirty-migration-rehearsal.mjs",
    "check:pre-retag": "node scripts/check-pre-retag.mjs",
    "typecheck": "cd client && npm run typecheck",
    "build": "cd client && npm run build",
    "wedding:cutover:preview": "node scripts/wedding-cutover-import-preview.mjs",
    "release:retag": "node scripts/release-retag.mjs",
    "push:main-hub": "pwsh -NoProfile -File scripts/push-main-hub.ps1",
    "push:main-hub:fast": "pwsh -NoProfile -File scripts/push-main-hub-fast.ps1",
    "help:aidocs:check": "uvx --from aidocs aidocs check",
    "generate:help": "cd client && npm run generate:help",
    "generate:help:screenshots": "cd client && npm run generate:help:screenshots --",
    "generate:help:refresh": "bash scripts/help-center-refresh.sh",
    "generate:help:components": "cd client && npm run generate:help:components --",
    "generate:help:components:rescan": "cd client && npm run generate:help:components:rescan --",
    "generate:help:components:cleanup": "cd client && npm run generate:help:components:cleanup --",
    "check:server": "bash scripts/cargo-server.sh check",
    "dev": "npm run dev:stack",
    "dev:stack": "bash scripts/dev-stack-preflight.sh && concurrently -n api,ui -c blue,magenta \"npm run dev:server\" \"npm run dev:client:wait\"",
    "dev:stack:with-bridge": "bash scripts/dev-stack-preflight.sh && concurrently -n api,ui,bridge -c blue,magenta,green \"npm run dev:server\" \"npm run dev:client:wait\" \"npm run dev:bridge\"",
    "dev:e2e": "npm run dev:e2e:stack",
    "dev:e2e:stack": "bash scripts/e2e-local-stack.sh",
    "dev:server": "bash scripts/dev-server.sh",
    "dev:client:wait": "wait-on -t 600000 tcp:127.0.0.1:3000 && npm run dev:client",
    "dev:client": "cd client && npm run dev",
    "dev:bridge": "wait-on -t 600000 tcp:127.0.0.1:3000 && cd counterpoint-bridge && node index.mjs",
    "seed:e2e:rms-fixtures": "bash scripts/seed_e2e_rms_fixtures.sh",
    "lint": "cd client && npm run lint",
    "test:e2e:list": "npm --prefix client run test:e2e -- --list",
    "test:e2e:local": "npm --prefix client run test:e2e -- --workers=1",
    "test:e2e:list:local": "npm --prefix client run test:e2e -- --list",
    "test:e2e:release": "npm --prefix client run test:e2e -- --workers=1",
    "test:e2e:visual": "cross-env E2E_RUN_VISUAL=1 npm --prefix client run test:e2e -- --workers=1",
    "test:e2e:high-risk": "npm --prefix client run test:e2e -- e2e/high-risk-regressions.spec.ts --workers=1",
    "test:e2e:phase2": "npm --prefix client run test:e2e -- e2e/phase2-finance-and-help-lifecycle.spec.ts --workers=1",
    "test:e2e:tender": "npm --prefix client run test:e2e -- e2e/tender-matrix-contract.spec.ts e2e/checkout-tender-financial-contract.spec.ts --workers=1",
    "test:e2e:rms": "npm --prefix client run test:e2e -- e2e/pos-rms-charge.spec.ts e2e/customers-rms-charge.spec.ts e2e/rms-reconciliation.spec.ts e2e/rms-permissions.spec.ts --workers=1",
    "docker:db": "docker compose up -d",
    "pack": "repomix"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "marked": "^18.0.4",
    "repomix": "^1.13.1",
    "shadcn": "^4.2.0",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "exceljs": "^4.4.0"
  }
}
