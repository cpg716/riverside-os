# Copy to `client/.env` (gitignored) for local Vite (`npm run dev` from `client/` or root `npm run dev`).
# See also `client/.env.pwa.example` for production-like PWA builds.

# API origin the browser calls (must match where Axum listens).
# VITE_API_BASE=http://127.0.0.1:3000

# Podium OAuth: optional. Defaults to ${origin}/callback (e.g. http://localhost:5173/callback).
# Set this when Podium only accepts an HTTPS URL (Vite server.https, tunnel) and it must match the app.
# VITE_PODIUM_OAUTH_REDIRECT_URI=https://localhost:5173/callback

# Optional: Sentry browser SDK (bug report failures + client errors). Omit in local dev unless debugging.
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Planned (ROSIE): Tauri may POST /v1/chat/completions to loopback llama-server; PWA uses VITE_API_BASE + /api/help/rosie/v1/chat/completions.
# See docs/PLAN_LOCAL_LLM_HELP.md and DEVELOPER.md (Environment variables).
# VITE_ROSIE_LLM_DIRECT=1
# VITE_ROSIE_LLM_HOST=127.0.0.1
# VITE_ROSIE_LLM_PORT=8080
