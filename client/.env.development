# Dev: empty API base = browser calls /api on the Vite host; vite.config.ts proxies to Rust on 127.0.0.1:3000.
# Required for LAN testing (http://<this-machine-ip>:5173 from phones/other PCs). Otherwise fetches go to 127.0.0.1 on *that* device and fail.
# Override in .env.development.local if needed (e.g. VITE_API_BASE=http://other-host:3000).
VITE_API_BASE=
