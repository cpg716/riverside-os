{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "opener:default",
    "opener:allow-open-path",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/llama-server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-kill"
  ]
}
