{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Riverside POS",
  "version": "0.3.1",
  "identifier": "com.riverside.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:register"
  },
  "app": {
    "windows": [
      {
        "title": "Riverside POS",
        "width": 1280,
        "height": 800,
        "maximized": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../dist"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/llama-server"
    ]
  }
}
