# Copy to `.env.pwa` (gitignored) and build with: npm run build:pwa
# PWA is usually served from the same HTTPS origin as the API (Axum static) or a CDN.
# Point the browser client at the API origin your staff will use in production.

VITE_API_BASE=https://pos.example.com

# Optional: Podium OAuth “Connect Podium” in Settings. When the PWA is served over HTTPS,
# `${origin}/callback` is used automatically; set this only if you need a fixed callback URL
# that differs from the page origin.
# VITE_PODIUM_OAUTH_REDIRECT_URI=https://pos.example.com/callback
