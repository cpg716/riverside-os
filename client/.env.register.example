# Copy to `.env.register` (gitignored) for Tauri desktop register builds.
# The cash-wrap PC often uses a fixed LAN API (or localhost if API is on the same machine).

VITE_API_BASE=http://192.168.1.50:3000

# Dev/E2E only: skip register keypad and auto-open with code 1234 (requires DB staff 1234 + matching pin).
# VITE_REGISTER_AUTH_BYPASS=true
