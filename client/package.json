{
  "name": "riverside-pos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:help": "node scripts/generate-help-manifest.mjs",
    "generate:help:components": "node scripts/generate-help-manifest.mjs --scaffold-components",
    "generate:help:components:rescan": "node scripts/generate-help-manifest.mjs --rescan-components",
    "prebuild": "node scripts/generate-help-manifest.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pwa": "tsc --noEmit && vite build --mode pwa",
    "build:register": "tsc --noEmit && vite build --mode register",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "tauri": "tauri",
    "tauri:dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
    "tauri:build": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build",
    "generate:staff-avatars": "node scripts/generate-staff-avatars.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@grapesjs/studio-sdk": "^1.0.60",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/react": "^8.55.1",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@tanstack/react-query": "^5.96.2",
    "@tauri-apps/api": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "localforage": "^1.10.0",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@dicebear/adventurer": "^9.4.2",
    "@dicebear/avataaars": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dicebear/lorelei": "^9.4.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.2.0"
  }
}
