{
  "name": "riverside-pos",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "generate:help": "node scripts/generate-help-manifest.mjs",
    "generate:help:screenshots": "node scripts/capture-help-screenshots.mjs",
    "generate:help:components": "node scripts/generate-help-manifest.mjs --scaffold-components",
    "generate:help:components:rescan": "node scripts/generate-help-manifest.mjs --rescan-components",
    "generate:help:components:cleanup": "node scripts/generate-help-manifest.mjs --rescan-components --delete-orphans",
    "prebuild": "node scripts/generate-help-manifest.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pwa": "tsc --noEmit && vite build --mode pwa",
    "build:register": "tsc --noEmit && vite build --mode register",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "test:e2e:release": "playwright test --workers=1",
    "test:e2e:visual": "cross-env E2E_RUN_VISUAL=1 playwright test --workers=1",
    "test:e2e:high-risk": "playwright test e2e/high-risk-regressions.spec.ts --workers=1",
    "test:e2e:phase2": "playwright test e2e/phase2-finance-and-help-lifecycle.spec.ts --workers=1",
    "test:e2e:tender": "playwright test e2e/tender-matrix-contract.spec.ts --workers=1",
    "test:e2e:rms": "playwright test e2e/pos-rms-charge.spec.ts e2e/corecard-webhooks.spec.ts e2e/customers-rms-charge.spec.ts e2e/rms-reconciliation.spec.ts e2e/rms-permissions.spec.ts --workers=1",
    "test:e2e:v020": "playwright test e2e/tax-exempt-and-stripe-branding.spec.ts --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "tauri": "tauri",
    "tauri:dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
    "tauri:build": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build",
    "generate:staff-avatars": "node scripts/generate-staff-avatars.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@grapesjs/studio-sdk": "^1.0.60",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/react": "^8.55.1",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@tanstack/react-query": "^5.96.2",
    "@tauri-apps/api": "^2.10.1",
    "@types/react-window": "^1.8.8",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "localforage": "^1.10.0",
    "lucide-react": "^0.468.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.7",
    "receiptline": "^4.0.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "tailwind-merge": "^3.5.0",
    "util": "^0.12.5",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@dicebear/adventurer": "^9.4.2",
    "@dicebear/avataaars": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dicebear/lorelei": "^9.4.2",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.2.0"
  }
}
