{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "riverside-deployment-manager",
  "version": "0.85.5",
  "identifier": "com.riverside.deployment-manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5179",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Riverside OS Deployment Manager",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
