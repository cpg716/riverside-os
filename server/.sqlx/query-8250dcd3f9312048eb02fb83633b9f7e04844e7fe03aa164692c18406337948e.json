  "query": "\n        SELECT ti.id, ti.title_snapshot AS title, ti.status::text AS status, ti.due_date, s.full_name AS assignee_name\n        FROM task_instance ti\n        LEFT JOIN staff s ON s.id = ti.assignee_staff_id\n        WHERE ti.id = $1\n        ",
