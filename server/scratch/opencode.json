opencode.json
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (LM Link)",
      "options": {
        "baseURL": "http://localhost:1234/v1",
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
        "qwen/qwen3.5-9b": {
          "name": "Qwen 3.5 9B (LM Studio LM Link)"
        }
      }
    }
  },
  "model": "lmstudio/qwen/qwen3.5-9b",
  "small_model": "lmstudio/qwen/qwen3.5-9b",
  "instructions": [
    "AGENTS.md",
    "DEVELOPER.md",
    "README.md"
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "target/**",
      ".next/**"
    ]
  }
}