# Copy to .env for local development.
#
# Local Postgres is expected to be the Docker Compose service `db` (see repo root docker-compose.yml).
# The server connects from your machine via the published Compose port (default 5433 → container 5432).

DATABASE_URL=postgresql://postgres:password@localhost:5433/riverside_os

# Optional: OpenTelemetry traces to an OTLP collector (Jaeger, Grafana Tempo, Datadog agent, etc.).
# Enable when either variable is non-empty, or set RIVERSIDE_OTEL_ENABLED=true (gRPC default http://localhost:4317).
# RIVERSIDE_OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# OTEL_SERVICE_NAME=riverside-server
# gRPC (default) or HTTP/protobuf for port 4318 pipelines: OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Optional: delete staff_bug_report rows older than N days (min 30; default 365). Daily ~04:00 local server time.
# RIVERSIDE_BUG_REPORT_RETENTION_DAYS=365

# ROS Dev Center E2E Health telemetry:
# Configure repository + token in Settings → ROS Dev Center. Do not place API tokens in this file.
# Optional: telemetry request timeout in milliseconds (default 8000, bounded 1000..30000).
# RIVERSIDE_OPS_E2E_GITHUB_TIMEOUT_MS=8000

# Counterpoint bridge sync token:
# Configure in Settings → Integrations → Counterpoint, then copy the same token to the Windows bridge runtime only.

# Visual Crossing API key:
# Configure in Settings → Integrations → Weather.

# Optional: force live weather on/off regardless of DB (1/true/yes/on or 0/false/no/off).
# RIVERSIDE_VISUAL_CROSSING_ENABLED=true

# Podium outbound SMS:
# Configure credentials and OAuth in Settings → Integrations → Podium.
# Obtain refresh token: Settings → Podium → Connect Podium (/callback must match Podium app;
# optional client/.env VITE_PODIUM_OAUTH_REDIRECT_URI — see client/.env.example).
# GET /api/settings/podium-oauth/authorize-url , POST /api/settings/podium-oauth/exchange (settings.admin).
# RIVERSIDE_PODIUM_OAUTH_TOKEN_URL=https://api.podium.com/oauth/token
#
# Optional: override REST API host for tests or non-default Podium regions (no trailing slash).
# RIVERSIDE_PODIUM_API_BASE=https://api.podium.com
#
# Inbound webhooks: POST /api/webhooks/podium (raw JSON body). When set, requests must include valid Podium signatures.
# Configure the Podium webhook secret in Settings → Integrations → Podium.
# Dev only: accept unsigned webhooks when secret is unset (never in production).
# RIVERSIDE_PODIUM_WEBHOOK_ALLOW_UNSIGNED=false
# When truthy, skip CRM ingest (no threads / inbox notifications from webhook); ledger still records new deliveries.
# RIVERSIDE_PODIUM_INBOUND_DISABLED=false

# First-party store email via IONOS IMAP/SMTP:
# Configure credentials in Settings → Integrations → Email.
# RIVERSIDE_EMAIL_SYNC_INTERVAL_SECS=300

# Online store customer accounts (JWT for /api/store/account/*). Generate: openssl rand -base64 48
# RIVERSIDE_STORE_CUSTOMER_JWT_SECRET=

# Integration credential encryption. Required before Settings-managed credentials can be saved.
# Generate for local/RC: openssl rand -hex 32
# RIVERSIDE_CREDENTIALS_KEY=

# Browser-facing production hardening. Recommended for any deployed server that serves a PWA/browser UI.
# When RIVERSIDE_STRICT_PRODUCTION=true:
# - RIVERSIDE_CORS_ORIGINS must be set
# - RIVERSIDE_STORE_CUSTOMER_JWT_SECRET must be set
# - FRONTEND_DIST must point to an existing built frontend directory
# RIVERSIDE_STRICT_PRODUCTION=true
# RIVERSIDE_CORS_ORIGINS=https://pos.example.com,https://backoffice.example.com
# FRONTEND_DIST=C:/RiversideOS/client/dist

# Optional public HTTPS base URL for provider callbacks and edge diagnostics.
# Use the origin only, without a trailing path. If this host is served through
# Cloudflare Tunnel, keep cloudflared running as a supervised host service.
# RIVERSIDE_PUBLIC_BASE_URL=https://ros.riversidemens.com
# RIVERSIDE_CLOUDFLARE_TUNNEL_HOSTNAME=ros.riversidemens.com

# Shippo live rates, labels, and tracking webhooks:
# Configure credentials in Settings → Integrations → Shippo.

# Optional: Meilisearch (fuzzy search). Start sidecar: docker compose up -d meilisearch
# Configure URL and API key in Settings → Integrations → Meilisearch.
# RIVERSIDE_MEILISEARCH_URL=http://127.0.0.1:7700
# RIVERSIDE_MEILISEARCH_API_KEY=dev_master_key_change_me
# After first deploy: POST /api/settings/meilisearch/reindex (settings.admin) or run until indexes are warm.

# Optional: CoreCredit / CoreCard broker settings.
# Configure API credentials in Settings → Integrations → CoreCard.
# Fake-host E2E uses these through `npm run dev:e2e`.
# Sandbox/live validation should use real values only through env files or the process environment.
# Preflight helper: `npm run validate:corecard:sandbox` or `npm run validate:corecard:live`
# RIVERSIDE_CORECARD_BASE_URL=https://sandbox-api.example.com
# RIVERSIDE_CORECARD_REGION=us
# RIVERSIDE_CORECARD_ENVIRONMENT=sandbox
# RIVERSIDE_CORECARD_TIMEOUT_SECS=15
# RIVERSIDE_CORECARD_REDACTION=strict
# RIVERSIDE_CORECARD_LOG_PAYLOADS=false
# Optional: inbound CoreCard webhooks. Accept shared-secret header
# `x-riverside-corecard-webhook-secret` or `Authorization: Bearer ...`.
# Dev only: allow unsigned CoreCard webhooks when no shared secret is configured.
# Leave this disabled for sandbox/live validation unless the CoreCard operator explicitly requires otherwise.
# RIVERSIDE_CORECARD_WEBHOOK_ALLOW_UNSIGNED=false
# Background repair polling cadence (seconds, minimum 60).
# Keep enabled during sandbox/live validation so missed webhook delivery can still be verified safely.
# RIVERSIDE_CORECARD_REPAIR_POLL_SECS=900
# Retain full redacted host/webhook payload snapshots for N days, then collapse to summary markers.
# Confirm retention/redaction policy with operations before live validation.
# RIVERSIDE_CORECARD_SNAPSHOT_RETENTION_DAYS=30

# Helcim card processing:
# Configure API token, terminal device codes, webhook secret, and API base URL in Settings → Integrations → Helcim.
# Dev only: simulate Helcim terminal approve/decline/cancel without Helcim hardware.
# This is ignored when RIVERSIDE_STRICT_PRODUCTION=true.
# HELCIM_SIMULATOR_ENABLED=false

# Optional: Metabase upstream for same-origin /metabase/* reverse proxy (Insights iframe). Default http://127.0.0.1:3001.
# Metabase container: set MB_SITE_URL to your public ROS URL including /metabase/ (Compose default
# http://localhost:5173/metabase/). Use env METABASE_SITE_URL if you open the app via LAN IP or 127.0.0.1.
# Metabase starts with root `docker compose up -d` (host :3001) when using the repo Compose file.
# Unset or empty = default http://127.0.0.1:3001. Set to 0, off, false, or disabled to disable (503).
# RIVERSIDE_METABASE_UPSTREAM=http://127.0.0.1:3001
#
# Metabase JWT secret:
# Configure in Settings → Integrations → Insights.
#
# Optional local / RC "silent shared auth" fallback for Metabase OSS when JWT SSO is disabled.
# When both email/password pairs are present, /api/insights/metabase-launch can background-login to
# Metabase and return /metabase/?metabase_session_id=... for the iframe.
# RIVERSIDE_METABASE_ADMIN_EMAIL=
# RIVERSIDE_METABASE_ADMIN_PASSWORD=
# RIVERSIDE_METABASE_STAFF_EMAIL=
# RIVERSIDE_METABASE_STAFF_PASSWORD=
# Optional: reporting-only Postgres connection that the Metabase metadata refresh script enforces.
# Use a real local/production secret after setting ALTER ROLE metabase_ro WITH PASSWORD '...'.
# RIVERSIDE_METABASE_REPORTING_DB_HOST=db
# RIVERSIDE_METABASE_REPORTING_DB_PORT=5432
# RIVERSIDE_METABASE_REPORTING_DB_NAME=riverside_os
# RIVERSIDE_METABASE_REPORTING_DB_USER=metabase_ro
# RIVERSIDE_METABASE_REPORTING_DB_PASSWORD=

# ROSIE Axum fallback: Host ROSIE HTTP origin for POST /api/help/rosie/v1/chat/completions (help-viewer auth).
# Canonical production stack: Gemma 4 E2B + SenseVoice Small + Kokoro-82M. Fallback policy lives in docs/ROSIE_HOST_STACK.md.
# `npm run dev` now auto-starts the local Gemma Host runtime and exports this upstream automatically
# when the approved local assets are present. Set it explicitly here when you want the server to use
# a different Host runtime, or disable dev autostart with `RIVERSIDE_DEV_AUTOSTART_ROSIE_HOST=0`.
# PWA and Tauri fallback use this path; Tauri may also call loopback directly — see docs/PLAN_LOCAL_LLM_HELP.md
# RIVERSIDE_LLAMA_UPSTREAM=http://127.0.0.1:8080

# Optional local dev override: set to 0 / false / no / off / disabled to prevent `npm run dev`
# from auto-starting the local Gemma Host runtime when `RIVERSIDE_LLAMA_UPSTREAM` targets loopback.
# RIVERSIDE_DEV_AUTOSTART_ROSIE_HOST=1
