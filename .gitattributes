# Force Windows line endings for PowerShell and batch scripts.
# Windows PowerShell 5.1 requires CRLF for here-strings (@"..."@) to parse correctly.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Database migration source files stay LF in Git. Windows release packages
# normalize packaged migration copies by historical checksum compatibility:
# migrations 001-101 ship CRLF, and 102+ ship LF.
*.sql text eol=lf
