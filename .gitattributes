# Force Windows line endings for PowerShell and batch scripts.
# Windows PowerShell 5.1 requires CRLF for here-strings (@"..."@) to parse correctly.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Database migrations are checksummed byte-for-byte in ROS. Keep packaged SQL
# line endings stable across Windows release runners and Main Hub installs.
*.sql text eol=lf
