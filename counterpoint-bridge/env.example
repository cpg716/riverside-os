# Riverside Counterpoint Sync Bridge
# Normal setup stores only these connection settings.
# NCR Counterpoint POS v8.4 SQL mappings are generated at runtime from INFORMATION_SCHEMA.

ROS_BASE_URL=http://127.0.0.1:3000
COUNTERPOINT_SYNC_TOKEN=change-me-long-random
SQL_CONNECTION_STRING=

# Optional expert-only overrides:
# CP_SQL_ENV_OVERRIDES=1 enables legacy CP_*_QUERY values in this file.
# Leave it unset for the supported v8.4 schema-probe path.
