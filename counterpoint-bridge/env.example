# After SQL_CONNECTION_STRING is set: double-click DISCOVER_SCHEMA.cmd (or: npm run discover).
# It reads INFORMATION_SCHEMA on YOUR Counterpoint DB and prints which .env lines to change — no ROS token needed.
# SSMS: ssms-find-your-tables.sql = list what your DB actually has (pattern + full dbo list).
#       ssms-list-bridge-tables.sql = compare that list to the bridge template names (present/missing).
# Same output is written to counterpoint-schema-report.txt (next to the bridge). Override path with CP_DISCOVER_OUTPUT=... or disable with CP_DISCOVER_OUTPUT=0.
#
# ═══ Edit these first ═══
# ROS machine (use LAN IP if bridge is on another PC), e.g. http://10.64.70.154:3000
ROS_BASE_URL=http://127.0.0.1:3000
# Same value as COUNTERPOINT_SYNC_TOKEN on the Riverside server (.env); restart server after changing.
COUNTERPOINT_SYNC_TOKEN=change-me-long-random
# Counterpoint company database (not master). Example:
# SQL_CONNECTION_STRING=Server=HOST\\INSTANCE;Database=YourCompanyDb;User Id=...;Password=...;Encrypt=true;TrustServerCertificate=true
SQL_CONNECTION_STRING=
# Drivers default to short SQL timeouts — heavy vendor/catalog queries can look like random “failures”. Defaults in bridge: 600s SQL / 300s ROS POST (override if needed):
# SQL_REQUEST_TIMEOUT_MS=600000
# SQL_CONNECT_TIMEOUT_MS=60000
# ROS_FETCH_TIMEOUT_MS=300000

# 1 = run one full import (all enabled entities) then exit — typical for bulk load; run START_BRIDGE.cmd again later to refresh.
# 0 = keep running and repeat every POLL_INTERVAL_MS (continuous catch-up + heartbeat).
RUN_ONCE=1
# After RUN_ONCE, the bridge waits for Enter before exiting so the console stays open (set 0 to exit immediately).
WAIT_AFTER_RUN_ONCE=1
POLL_INTERVAL_MS=15000
BATCH_SIZE=200

# Historical import floor for ticket / note / loyalty templates: use __CP_IMPORT_SINCE__ in CP_*_QUERY strings (expanded at runtime).
# Default one-time migration cutover floor: 2018-01-01 (see docs/COUNTERPOINT_ONE_TIME_IMPORT.md).
CP_IMPORT_SINCE=2018-01-01

# After SQL connects, probe INFORMATION_SCHEMA for IM_INV cost column names, IM_ITEM vendor column aliases,
# PO_VEND column names (fast vendor list), and optional PO_VEND_ITEM item→vendor link. One-line log: [auto-schema] …
# Set 0 to skip (you tune every CP_*_QUERY by hand).
# CP_AUTO_SCHEMA=1
#
# default = use only the CP_*_QUERY lines below (still runs auto-schema probe when CP_AUTO_SCHEMA=1).
# maximal = for any of customers / inventory / catalog / vendor_items / category_masters, if the env line is EMPTY,
# substitute a built-in wide query (ticket/gift/open-doc SQL still comes from env). Expert SQL in .env always wins.
# CP_IMPORT_SCOPE=default

# IM_INV / catalog parent join location id (default MAIN). Many Counterpoint DBs use another code — set to match SSMS:
# CP_INVENTORY_LOC_ID=MAIN
# CP_CATALOG_INV_LOC_ID=MAIN

# ── PS_TKT_HIST doc type: bridge omits DOC_TYP filters by default (many CP DBs have no DOC_TYP column).
# Set CP_OMIT_PS_TKT_DOC_TYP_FILTER=0 if your PS_TKT_HIST has DOC_TYP and you want “closed ticket” typing only.
# If the column exists but is named differently: CP_OMIT_PS_TKT_DOC_TYP_FILTER=0 and CP_TKT_DOC_TYP_COLUMN=DOC_TYPE
#
# ── IM_ITEM vendor code: template references i.VEND_NO. If discover finds another column name:
# CP_IM_ITEM_VENDOR_COLUMN=PUR_VND
# If catalog/vendors fail on Invalid column VEND_NO on IM_ITEM, enable (discover often recommends this).
# Leave UNSET for normal IM_ITEM.VEND_NO databases — do not default to po_vend_item or primary vendor SQL can break.
# CP_IM_ITEM_VENDOR_SOURCE=po_vend_item

# CP_*_QUERY lines follow the Counterpoint → ROS field map (company DB). Adjust only if SSMS column names differ.
#
# Schema compatibility: SQL Server validates every column you name (including each argument of COALESCE). Defaults avoid
# optional columns many CP builds lack (USR_GRP_ID, PTS_BAL, TOT_AMT_DUE, VEND_COST). Cost fields use LST_COST only — if
# IM_INV uses AVG_COST instead, change LST_COST to AVG_COST in CP_INVENTORY_QUERY / CP_CATALOG_QUERY / CP_CATALOG_CELLS_QUERY.
#
# Table names in optional queries (gift certs, loyalty history) match NCR Counterpoint documentation / common CP schemas —
# they were not invented for ROS, but many stores have no gift-cert or loyalty module, so those tables may not exist.
# Authoritative list: npm run discover / DISCOVER_SCHEMA.cmd (INFORMATION_SCHEMA on YOUR company DB). Common typo: PS_LOY_* (LOY) not LOT.
#
# Core objects this bridge targets by default: SY_USR, PS_SLS_REP, PO_BUYER; PO_VEND, PO_VEND_ITEM; AR_CUST, AR_CUST_NOTE;
#   IM_ITEM, IM_INV_CELL, IM_PRC, IM_BARCOD, IM_INV; PS_TKT_HIST + LIN + PMT (+ optional matrix cells: PS_TKT_HIST_CELL or PS_TKT_HIST_LIN_CELL; PS_TKT_HIST_GFT).
# Optional modules: SY_GFT_CERT / SY_GFT_CERT_HIST (some builds use SY_GFC / SY_GFC_HIST instead — rewrite CP_GIFT_CARDS_* if needed); PS_LOY_PTS_HIST (some builds use AR_LOY_PT_ADJ_* — rewrite CP_LOYALTY_HIST_QUERY if needed).
# Open special orders: PS_DOC* wired when SYNC_OPEN_DOCS=1 (requires ROS migration 91 + /open-docs). Phase 2: PO_RECV_*; PO_HDR/PO_LIN → ROS PO receiving — see runbook.

# Optional: path to JSON file storing last cursor (cust_no / sku) per entity
CURSOR_STATE_FILE=./.counterpoint-bridge-state.json

# ═══════════════════════════════════════════════════════════════════════════════
# ENTITY SYNC FLAGS — set to 1 to enable, 0 to disable
# IMPORT ORDER IS FIXED in index.mjs (same as below). Do not rely on flag order in this file.
# staff → sales_rep_stubs? (auto when CP_SALES_REPS_QUERY empty) → vendors → customers → store_credit_opening? →
#   customer_notes? → catalog → inventory → vendor_items? → gift_cards? → tickets? → open_docs? → loyalty_hist?
#
# Startup guard: impossible combinations exit with [sync-plan] errors (e.g. tickets without catalog).
# For expert incremental refresh only (ROS already seeded): SYNC_RELAXED_DEPENDENCIES=1
# ═══════════════════════════════════════════════════════════════════════════════

# SYNC_RELAXED_DEPENDENCIES=0

# --- Staff (SY_USR + PS_SLS_REP + PO_BUYER → staff + counterpoint_staff_map) ---
# Sync FIRST so customer.sls_rep and ticket.usr_id / sls_rep resolve to staff.id.
SYNC_STAFF=1
# SY_USR map: USR_ID (PK), NAM, INITIALS, PHONE_1, EMAIL_ADRS_1.
CP_USERS_QUERY=SELECT RTRIM(LTRIM(USR_ID)) AS usr_id, RTRIM(LTRIM(NAM)) AS nam, RTRIM(LTRIM(EMAIL_ADRS_1)) AS email_adrs, RTRIM(LTRIM(SEC_COD)) AS usr_grp_id FROM SY_USR ORDER BY USR_ID
# PS_SLS_REP: leave query EMPTY if the table is not visible (discover lists it as missing). Bridge then sends distinct SLS_REP from
# AR_CUST + PS_TKT_HIST to ROS POST /sales-rep-stubs after SY_USR staff sync. If the table IS visible, uncomment:
# CP_SALES_REPS_QUERY=SELECT RTRIM(LTRIM(SLS_REP)) AS sls_rep, RTRIM(LTRIM(NAM)) AS nam, COMMIS_PCT AS commis_pct, CAST(NULL AS NVARCHAR(32)) AS commis_meth FROM PS_SLS_REP ORDER BY SLS_REP
CP_SALES_REPS_QUERY=
# PO_BUYER: leave EMPTY if not visible. Otherwise:
# CP_BUYERS_QUERY=SELECT RTRIM(LTRIM(BUYER_ID)) AS buyer_id, RTRIM(LTRIM(NAM)) AS nam FROM PO_BUYER ORDER BY BUYER_ID
CP_BUYERS_QUERY=

# --- Vendors (PO_VEND → vendors.vendor_code) ---
# Bridge 0.6.18+: default vendor pass is FAST — all rows from PO_VEND (built-in SQL: VEND_NO, NAM, TERMS_COD). It does NOT run CP_VENDORS_QUERY unless you opt in.
# Keep SYNC_VENDORS_FILTERED unset or 0 for bulk imports (avoids heavy EXISTS + ticket joins and SQL/ROS timeouts). npm run discover checks PO_VEND columns — if TERMS_COD or NAM differ, set CP_VENDORS_FAST_QUERY.
# SYNC_VENDORS_FILTERED=1 — only if you need “active catalog / ticket-scoped” vendor subset; then CP_VENDORS_QUERY below is required and must match your schema (IM_ITEM vendor column + CP_IM_ITEM_VENDOR_SOURCE if no VEND_NO on IM_ITEM).
# CP_VENDORS_FAST_QUERY=SELECT RTRIM(LTRIM(VEND_NO)) AS vend_no, RTRIM(LTRIM(NAM)) AS name, CAST(NULL AS NVARCHAR(64)) AS payment_terms FROM PO_VEND WHERE VEND_NO IS NOT NULL ORDER BY VEND_NO
# TERMS_COD (when present) → vendors.payment_terms. account_number: add AS account_number if PO_VEND exposes an AP #.
SYNC_VENDORS=1
# Optional heavy filter (used only when SYNC_VENDORS_FILTERED=1):
# CP_VENDORS_QUERY=SELECT RTRIM(LTRIM(v.VEND_NO)) AS vend_no, RTRIM(LTRIM(v.NAM)) AS name, RTRIM(LTRIM(v.TERMS_COD)) AS payment_terms FROM PO_VEND v WHERE v.VEND_NO IS NOT NULL AND EXISTS (SELECT 1 FROM IM_ITEM i WHERE RTRIM(LTRIM(i.VEND_NO)) = RTRIM(LTRIM(v.VEND_NO)) AND RTRIM(LTRIM(i.ITEM_NO)) <> N'' AND (EXISTS (SELECT 1 FROM IM_INV inv WHERE inv.ITEM_NO = i.ITEM_NO AND inv.LOC_ID = N'MAIN' AND CAST(inv.QTY_ON_HND AS INT) <> 0) OR EXISTS (SELECT 1 FROM IM_INV_CELL g WHERE g.ITEM_NO = i.ITEM_NO AND CAST(g.QTY_ON_HND AS INT) <> 0) OR RTRIM(LTRIM(i.ITEM_NO)) IN (SELECT DISTINCT RTRIM(LTRIM(l.ITEM_NO)) FROM PS_TKT_HIST_LIN l INNER JOIN PS_TKT_HIST h ON h.TKT_NO = l.TKT_NO WHERE h.DOC_TYP = N'T' AND h.TKT_DT >= '__CP_IMPORT_SINCE__'))) ORDER BY v.VEND_NO

# --- Customers (AR_CUST → customers) ---
# Set to 0 to disable customer sync loop
SYNC_CUSTOMERS=1
# AR_CUST map: CUST_NO, NAM, FST_NAM, LST_NAM, ADRS_*, CITY, STATE, ZIP_COD, PHONE_1, EMAIL_ADRS_1, CUST_TYP, SLS_REP. Loyalty: use one real column only — LOY_PTS_BAL, PTS_BAL, or CAST(0 AS INT) AS pts_bal if none (discover/SSMS).
# Shipped template imports the full AR_CUST customer base so customer identity, loyalty balance, and open-doc ownership are not silently truncated by ticket/note filters.
# If you intentionally want a narrower rehearsal scope, replace this with a filtered AR_CUST query after validating the downstream impact.
# SYNC_STORE_CREDIT_OPENING=1: set CP_CUSTOMER_STORE_CREDIT_EXISTS (below) — bridge appends OR EXISTS(…) before ORDER BY. OPEN_DOCS still needs manual OR EXISTS on PS_DOC if required.
# If AR_CUST has no MERCH_CR_BAL, set SYNC_STORE_CREDIT_OPENING=0 until you map the real column (e.g. STR_CR_BAL) in BOTH store-credit queries below.
# Customer import: importing all customers in v8.2 to ensure no "Invalid Column" errors in subqueries.
CP_CUSTOMERS_QUERY=SELECT RTRIM(LTRIM(CAST(c.CUST_NO AS NVARCHAR(64)))) AS cust_no, RTRIM(LTRIM(c.FST_NAM)) AS first_name, RTRIM(LTRIM(c.LST_NAM)) AS last_name, RTRIM(LTRIM(c.NAM)) AS full_name, RTRIM(LTRIM(c.EMAIL_ADRS_1)) AS email, RTRIM(LTRIM(c.PHONE_1)) AS phone, RTRIM(LTRIM(c.ADRS_1)) AS address_line1, RTRIM(LTRIM(c.ADRS_2)) AS address_line2, RTRIM(LTRIM(c.CITY)) AS city, RTRIM(LTRIM(c.STATE)) AS state, RTRIM(LTRIM(c.ZIP_COD)) AS postal_code, RTRIM(LTRIM(c.CUST_TYP)) AS cust_typ, c.LOY_PTS_BAL AS pts_bal, RTRIM(LTRIM(c.SLS_REP)) AS sls_rep FROM AR_CUST c WHERE ('1'='1') ORDER BY c.CUST_NO

# --- Customer Notes (AR_CUST_NOTE → customer_timeline_notes) ---
# Optional: NOTE_DAT >= '__CP_IMPORT_SINCE__' trims old notes (expanded to CP_IMPORT_SINCE).
SYNC_CUSTOMER_NOTES=1
CP_CUSTOMER_NOTES_QUERY=SELECT RTRIM(LTRIM(CUST_NO)) AS cust_no, CAST(NOTE_ID AS NVARCHAR(64)) AS note_id, CONVERT(varchar, NOTE_DAT, 126) + 'Z' AS note_date, NOTE_TXT AS note_text, RTRIM(LTRIM(USR_ID)) AS usr_id FROM AR_CUST_NOTE WHERE NOTE_DAT >= '__CP_IMPORT_SINCE__' ORDER BY CUST_NO, NOTE_ID

# --- Inventory (stock-only update — existing variants) ---
SYNC_INVENTORY=1
# IM_INV map: ITEM_NO, LOC_ID, QTY_ON_HND, LST_COST (if your IM_INV has no LST_COST, replace with AVG_COST or LAST_COST per SSMS — use only one column name; COALESCE fails if any listed column is missing).
# Default SKIPS dead SKUs: MAIN LOC QTY_ON_HND <> 0 OR ITEM_NO on an in-range closed-ticket line (same “active” story as CP_CATALOG_QUERY for single-SKU items; matrix parents with stock only in IM_INV_CELL still enter catalog via cell qty / ticket rules there).
# Full IM_INV (all MAIN rows): use instead —
# CP_INVENTORY_QUERY=SELECT RTRIM(LTRIM(ITEM_NO)) AS sku, CAST(QTY_ON_HND AS INT) AS stock_on_hand, RTRIM(LTRIM(ITEM_NO)) AS counterpoint_item_key, LST_COST AS last_cost FROM IM_INV WHERE ITEM_NO IS NOT NULL AND LOC_ID = 'MAIN'
CP_INVENTORY_QUERY=SELECT RTRIM(LTRIM(i.ITEM_NO)) AS sku, CAST(i.QTY_ON_HND AS INT) AS stock_on_hand, RTRIM(LTRIM(i.ITEM_NO)) AS counterpoint_item_key, i.LST_COST AS last_cost FROM IM_INV i WHERE i.ITEM_NO IS NOT NULL AND i.LOC_ID = 'MAIN' AND (CAST(i.QTY_ON_HND AS INT) <> 0 OR RTRIM(LTRIM(i.ITEM_NO)) IN (SELECT DISTINCT RTRIM(LTRIM(l.ITEM_NO)) FROM PS_TKT_HIST_LIN l INNER JOIN PS_TKT_HIST h ON h.TKT_NO = l.TKT_NO WHERE h.DOC_TYP = N'T' AND h.TKT_DT >= '__CP_IMPORT_SINCE__'))

# --- Category masters (distinct CP retail categories → ROS categories + counterpoint_category_map) ---
# Runs BEFORE catalog so IM_ITEM rows resolve category_id. Set SYNC_CATEGORY_MASTERS=0 to skip (manual map only).
# Default uses CATEG_COD only — many IM_ITEM builds have no SUBCATEG_COD. If yours does, use the CONCAT form in a comment below.
SYNC_CATEGORY_MASTERS=1
CP_CATEGORY_MASTERS_QUERY=SELECT DISTINCT RTRIM(LTRIM(i.CATEG_COD)) AS cp_category, RTRIM(LTRIM(i.CATEG_COD)) AS display_name FROM IM_ITEM i WHERE RTRIM(LTRIM(i.ITEM_NO)) <> N'' AND NULLIF(RTRIM(LTRIM(i.CATEG_COD)), N'') IS NOT NULL ORDER BY cp_category
# With subcategory (only if SUBCATEG_COD exists): CP_CATEGORY_MASTERS_QUERY=SELECT DISTINCT CONCAT(RTRIM(LTRIM(i.CATEG_COD)), CASE WHEN NULLIF(RTRIM(LTRIM(i.SUBCATEG_COD)), N'') IS NOT NULL THEN N' / ' + RTRIM(LTRIM(i.SUBCATEG_COD)) ELSE N'' END) AS cp_category, ...

# --- Catalog (product + variant upsert; creates items when missing) ---
# Sync AFTER vendors so VEND_NO resolves to products.primary_vendor_id.
SYNC_CATALOG=1
# “Active” items only (aligned with CP_INVENTORY_QUERY): in-range closed-ticket line, OR MAIN IM_INV QTY_ON_HND ≠ 0, OR matrix cell QTY_ON_HND ≠ 0. Does not use IM_HST_TRX (adjust in SSMS if you need receipt/adj history). If ticket lines use CELL_DESCR as ITEM_NO only, add an OR join from IM_INV_CELL to PS_TKT_HIST_LIN (see SYNC_GUIDE).
# IM_ITEM map: ITEM_NO, DESCR, LONG_DESCR, CATEG_COD, VEND_NO (or CP_IM_ITEM_VENDOR_COLUMN remap). is_grd from IM_INV_CELL. IM_PRC / IM_BARCOD / IM_INV; remove PRC_2/PRC_3 if missing.
# IM_PRC.PRC_2 / PRC_3: stored on variants as counterpoint_prc_2/3 (reference). ROS employee sale price is cost-plus in ROS, not these tiers.
CP_CATALOG_QUERY=SELECT RTRIM(LTRIM(i.ITEM_NO)) AS item_no, RTRIM(LTRIM(i.DESCR)) AS descr, i.LONG_DESCR AS long_descr, RTRIM(LTRIM(i.CATEG_COD)) AS categ_cod, RTRIM(LTRIM(i.VEND_NO)) AS vend_no, CASE WHEN EXISTS (SELECT 1 FROM IM_INV_CELL g WHERE g.ITEM_NO = i.ITEM_NO) THEN 'Y' ELSE 'N' END AS is_grd, p.PRC_1 AS prc_1, p.PRC_2 AS prc_2, p.PRC_3 AS prc_3, inv.LST_COST AS lst_cost, b.BARCOD AS barcode FROM IM_ITEM i LEFT JOIN IM_PRC p ON p.ITEM_NO = i.ITEM_NO LEFT JOIN IM_INV inv ON inv.ITEM_NO = i.ITEM_NO AND inv.LOC_ID = 'MAIN' LEFT JOIN IM_BARCOD b ON b.ITEM_NO = i.ITEM_NO WHERE RTRIM(LTRIM(i.ITEM_NO)) <> N'' AND (EXISTS (SELECT 1 FROM IM_INV inv2 WHERE inv2.ITEM_NO = i.ITEM_NO AND inv2.LOC_ID = N'MAIN' AND CAST(inv2.QTY_ON_HND AS INT) <> 0) OR EXISTS (SELECT 1 FROM IM_INV_CELL g2 WHERE g2.ITEM_NO = i.ITEM_NO AND CAST(g2.QTY_ON_HND AS INT) <> 0) OR RTRIM(LTRIM(i.ITEM_NO)) IN (SELECT DISTINCT RTRIM(LTRIM(l.ITEM_NO)) FROM PS_TKT_HIST_LIN l INNER JOIN PS_TKT_HIST h ON h.TKT_NO = l.TKT_NO WHERE h.DOC_TYP = N'T' AND h.TKT_DT >= '__CP_IMPORT_SINCE__')) ORDER BY i.ITEM_NO
# IM_INV_CELL: ITEM_NO (parent), DIM_1_VAL / DIM_2_VAL / DIM_3_VAL, QTY_ON_HND, MIN_QTY. Matrix ROS key = parent|dim1|dim2|dim3 (same key from PS_TKT_HIST_CELL or PS_TKT_HIST_LIN_CELL when CP_TICKET_CELLS_QUERY is set).
# If your cells use CELL_DESCR as the child ITEM_NO, replace counterpoint_item_key/sku with RTRIM(c.CELL_DESCR) and join IM_BARCOD b ON b.ITEM_NO = c.CELL_DESCR.
# DIM_3_VAL: default uses 3 dimensions. Auto-schema (CP_AUTO_SCHEMA=1, default) detects actual column names (DIM_3 vs DIM_3_VAL etc.) and rewrites at runtime. If cells query fails, parent catalog still imports.
# IM_INV_CELL: v8.2 uses DIM_1_UPR, DIM_2_UPR, DIM_3_UPR.
CP_CATALOG_CELLS_QUERY=SELECT RTRIM(LTRIM(c.ITEM_NO)) AS parent_item_no, CONCAT(RTRIM(LTRIM(c.ITEM_NO)), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_1_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_2_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_3_UPR))), N'')) AS counterpoint_item_key, CONCAT(RTRIM(LTRIM(c.ITEM_NO)), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_1_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_2_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_3_UPR))), N'')) AS sku, (RTRIM(LTRIM(ISNULL(CONVERT(NVARCHAR(80), c.DIM_1_UPR), N''))) + CASE WHEN c.DIM_2_UPR IS NOT NULL THEN N' / ' + RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_2_UPR))) ELSE N'' END + CASE WHEN c.DIM_3_UPR IS NOT NULL THEN N' / ' + RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_3_UPR))) ELSE N'' END) AS variation_label, CAST(c.QTY_ON_HND AS INT) AS stock_on_hand, CAST(c.MIN_QTY AS INT) AS min_qty, p.PRC_1 AS retail_price, p.PRC_2 AS prc_2, p.PRC_3 AS prc_3, inv.LST_COST AS unit_cost, CAST(NULL AS NVARCHAR(50)) AS barcode FROM IM_INV_CELL c LEFT JOIN IM_PRC p ON p.ITEM_NO = c.ITEM_NO LEFT JOIN IM_INV inv ON inv.ITEM_NO = c.ITEM_NO AND inv.LOC_ID = 'MAIN' WHERE EXISTS (SELECT 1 FROM IM_ITEM i WHERE i.ITEM_NO = c.ITEM_NO AND RTRIM(LTRIM(i.ITEM_NO)) <> N'')

# --- Gift Cards (Standard: SY_GFT_CERT; Custom: SY_GFC) ---
# Your SQL probe found SY_GFC instead of SY_GFT_CERT.
# Rewrite these queries if your table is SY_GFC.
SYNC_GIFT_CARDS=1
# Standard SY_GFT_CERT example:
# CP_GIFT_CARDS_QUERY=SELECT RTRIM(LTRIM(GFT_CERT_NO)) AS gift_cert_no, CAST(ISNULL(BAL, 0) AS DECIMAL(18,2)) AS balance FROM SY_GFT_CERT WHERE CAST(ISNULL(BAL, 0) AS DECIMAL(18,2)) > CAST(0 AS DECIMAL(18,2))
# Custom SY_GFC example (Adjust column names based on your SSMS grid):
CP_GIFT_CARDS_QUERY=SELECT RTRIM(LTRIM(GFC_NO)) AS gift_cert_no, CAST(ISNULL(CURR_AMT, 0) AS DECIMAL(18,2)) AS balance FROM SY_GFC WHERE ISNULL(CURR_AMT, 0) > 0
CP_GFT_CERT_HIST_QUERY=SELECT CAST(ISNULL([ROW_TS], 0) AS NVARCHAR(64)) AS counterpoint_gft_hist_seq, RTRIM(LTRIM([GFC_NO])) AS gift_cert_no, CONVERT(varchar, [RS_UTC_DT], 126) + 'Z' AS date_time, [AMT] AS amount, CAST(NULL AS NVARCHAR(32)) AS [doc_no], RTRIM(LTRIM([DESCR])) AS reason FROM SY_GFC_HIST WHERE [RS_UTC_DT] >= '__CP_IMPORT_SINCE__'

# --- Ticket history (PS_TKT_HIST → orders + order_items + payment_transactions) ---
SYNC_TICKETS=1
# ── Date cutoff ──
# Add  AND BUS_DAT >= '__CP_IMPORT_SINCE__' for a bounded history import (recommended).
# Remove the date clause to import ALL history (large volume).
# PS_TKT_HIST totals: use TOT when TOT_EXTD_PRC is missing (discover). If you have TOT_EXTD_PRC: use it AS total_price. TOT_AMT_DUE: (TOT_EXTD_PRC - TOT_AMT_DUE) AS amount_paid.
# Server ingest now prefers the summed PS_TKT_HIST_PMT / PS_TKT_HIST_GFT tender rows for amount_paid when those rows are present; header amount_paid is a fallback only.
# PS_TKT_HIST: v8.2 uses TOT for total and TKT_DT for the exact timestamp.
CP_TICKETS_QUERY=SELECT RTRIM(LTRIM([TKT_NO])) AS ticket_ref, RTRIM(LTRIM([CUST_NO])) AS cust_no, CONVERT(varchar, [TKT_DT], 126) + 'Z' AS booked_at, [TOT] AS total_price, [TOT] AS amount_paid, RTRIM(LTRIM([USR_ID])) AS usr_id, RTRIM(LTRIM([SLS_REP])) AS sls_rep FROM PS_TKT_HIST WHERE [TKT_TYP] = 'T' AND [TKT_DT] >= '__CP_IMPORT_SINCE__' ORDER BY [TKT_DT], [TKT_NO]
# PS_TKT_HIST_LIN: TKT_NO, LIN_SEQ_NO, ITEM_NO, QTY_SOLD, PRC, UNIT_COST. Many CP builds have no DISC_AMT — omit (ROS ignores it).
# ITEM_DESCR: many CP builds lack this column — default uses NULL. If yours has it: replace CAST(NULL …) with RTRIM(LTRIM(ITEM_DESCR)) AS description.
# Auto-schema (CP_AUTO_SCHEMA=1, default) also fixes this at runtime. LIN_SEQ_NO needed for PS_TKT_HIST_LIN_CELL join.
# PS_TKT_HIST_LIN: TKT_NO, LIN_SEQ_NO, ITEM_NO, QTY_SOLD, PRC, UNIT_COST. Many CP builds have no DISC_AMT — omit (ROS ignores it).
# ITEM_DESCR: many CP builds lack this column — default uses NULL. If yours has it: replace CAST(NULL …) with RTRIM(LTRIM(ITEM_DESCR)) AS description.
# REAS_COD: Optional — maps to counterpoint_reason_code on line items for return/void reporting.
CP_TICKET_LINES_QUERY=SELECT RTRIM(LTRIM([TKT_NO])) AS ticket_ref, [LIN_SEQ_NO] AS lin_seq_no, RTRIM(LTRIM([ITEM_NO])) AS sku, RTRIM(LTRIM([ITEM_NO])) AS counterpoint_item_key, [QTY_SOLD] AS quantity, [PRC] AS unit_price, [UNIT_COST] AS unit_cost, CAST(NULL AS NVARCHAR(255)) AS description, RTRIM(LTRIM([RET_REAS])) AS reason_code FROM PS_TKT_HIST_LIN WHERE [TKT_NO] IN (SELECT [TKT_NO] FROM PS_TKT_HIST WHERE [TKT_TYP] = 'T' AND [TKT_DT] >= '__CP_IMPORT_SINCE__')
# PS_TKT_HIST_NOTE: Optional — joins to header to attach comments to orders in ROS. Enable SYNC_TICKET_NOTES=1.
SYNC_TICKET_NOTES=1
CP_TICKET_NOTES_QUERY=SELECT RTRIM(LTRIM(h.[TKT_NO])) AS ticket_ref, n.[NOTE] AS note FROM PS_TKT_HIST_NOTE n INNER JOIN PS_TKT_HIST h ON n.[DOC_ID] = h.[DOC_ID] WHERE h.[TKT_TYP] = 'T' AND h.[TKT_DT] >= '__CP_IMPORT_SINCE__'
# PS_TKT_HIST_CELL or PS_TKT_HIST_LIN_CELL: leave EMPTY if no matrix cells; otherwise matrix lines need dim values for catalog keys.
# Discover: v8 often has PS_TKT_HIST_LIN_CELL (not PS_TKT_HIST_CELL). Uncomment and fix column names in SSMS if needed:
# CP_TICKET_CELLS_QUERY=SELECT RTRIM(LTRIM(DOC_ID)) AS tkt_no, LIN_SEQ_NO AS lin_seq_no, DIM_1_VAL AS dim_1_val, DIM_2_VAL AS dim_2_val, DIM_3_VAL AS dim_3_val FROM PS_TKT_HIST_LIN_CELL WHERE DOC_ID IN (SELECT DOC_ID FROM PS_TKT_HIST WHERE DOC_TYP = 'T' AND BUS_DAT >= '__CP_IMPORT_SINCE__')
CP_TICKET_CELLS_QUERY=
# PS_TKT_HIST_PMT: PMT_TYP, AMT. If gift tenders are already in PMT, set CP_TICKET_GIFT_QUERY empty to avoid double-counting with PS_TKT_HIST_GFT.
CP_TICKET_PAYMENTS_QUERY=SELECT RTRIM(LTRIM([TKT_NO])) AS ticket_ref, RTRIM(LTRIM([PAY_COD])) AS pmt_typ, [AMT] AS amount, CAST(NULL AS NVARCHAR(32)) AS gift_cert_no FROM PS_TKT_HIST_PMT WHERE [TKT_NO] IN (SELECT [TKT_NO] FROM PS_TKT_HIST WHERE [TKT_DT] >= '__CP_IMPORT_SINCE__')
# PS_TKT_HIST_GFT: leave EMPTY if table not visible or SYNC_GIFT_CARDS=0. Otherwise uncomment a SELECT like the old template.
CP_TICKET_GIFT_QUERY=

# --- Loyalty history (Standard: PS_LOY_PTS_HIST; Custom: AR_LOY_PT_ADJ_HIST) ---
# Your SQL probe found AR_LOY_PT_ADJ_HIST.
SYNC_LOYALTY_HIST=1
# Custom AR_LOY path example (v8.2 uses TRX_DAT and NO_OF_PTS):
CP_LOYALTY_HIST_QUERY=SELECT RTRIM(LTRIM(CAST(CUST_NO AS NVARCHAR(64)))) AS cust_no, TRX_DAT AS bus_dat, NO_OF_PTS AS pts_earnd, CAST(0 AS INT) AS pts_redeemd, RTRIM(LTRIM(CAST(DOC_NO AS NVARCHAR(128)))) AS ref_no FROM AR_LOY_PT_ADJ_HIST WHERE TRX_DAT >= '__CP_IMPORT_SINCE__' ORDER BY CUST_NO, TRX_DAT, DOC_NO

# --- Historical Receiving History (PO_RECVR_HIST_LIN → historical margin analytics) ---
# v8.2 uses RECVR_DAT and COST in PO_RECVR_HIST_LIN.
SYNC_RECEIVING_HISTORY=1
CP_RECEIVING_HISTORY_QUERY=SELECT RTRIM(LTRIM(VEND_NO)) AS vend_no, RTRIM(LTRIM(ITEM_NO)) AS item_no, CONVERT(varchar, RECVR_DAT, 126) + 'Z' AS recv_dat, COST AS unit_cost, QTY_RECVD AS qty_recv, RTRIM(LTRIM(PO_NO)) AS po_no, RTRIM(LTRIM(RECVR_NO)) AS recv_no FROM PO_RECVR_HIST WHERE RECVR_DAT >= '__CP_IMPORT_SINCE__' ORDER BY RECVR_DAT, RECVR_NO

# --- Store Credit Opening Balance (Now Enabled) ---
# Your SQL probe found SY_STC. We are now activating this sync.
SYNC_STORE_CREDIT_OPENING=1
# Use this fragment to find customers with open credits in SY_STC (v8.2 uses ORIG_CUST_NO):
CP_CUSTOMER_STORE_CREDIT_EXISTS=SELECT 1 FROM SY_STC sc WHERE RTRIM(LTRIM(CAST(sc.ORIG_CUST_NO AS NVARCHAR(64)))) = RTRIM(LTRIM(CAST(c.CUST_NO AS NVARCHAR(64)))) AND CAST(ISNULL(sc.CURR_AMT, 0) AS DECIMAL(18,2)) > 0
# Full Store Credit query:
CP_STORE_CREDIT_QUERY=SELECT RTRIM(LTRIM(CAST(ORIG_CUST_NO AS NVARCHAR(64)))) AS cust_no, CAST(ISNULL(CURR_AMT, 0) AS DECIMAL(18,2)) AS balance FROM SY_STC WHERE CAST(ISNULL(CURR_AMT, 0) AS DECIMAL(18,2)) > 0 ORDER BY ORIG_CUST_NO

# --- Open Counterpoint documents / layaways (PS_DOC → ROS orders + counterpoint_doc_ref) ---
# Requires migration 91, catalog + tickets import so variants exist; runs after closed ticket history.
# --- Open Counterpoint documents / layaways (PS_DOC -> ROS orders) ---
SYNC_OPEN_DOCS=1
# v8.2 uses TKT_NO (Ref), TKT_DT, and DOC_TYP (O/L). Totals joined from PS_DOC_HDR_TOT.
# Server ingest now prefers the summed PS_DOC_PMT tender rows for amount_paid when those rows are present; header amount_paid is a fallback only.
CP_OPEN_DOCS_QUERY=SELECT RTRIM(LTRIM(h.[DOC_ID])) AS doc_ref, RTRIM(LTRIM(h.[CUST_NO])) AS cust_no, CONVERT(varchar, h.[TKT_DT], 126) + 'Z' AS booked_at, RTRIM(LTRIM(h.[USR_ID])) AS usr_id, RTRIM(LTRIM(h.[SLS_REP])) AS sls_rep, RTRIM(LTRIM(h.[DOC_TYP])) AS doc_typ, t.[TOT] AS total_price, t.[TOT_TND] AS amount_paid FROM PS_DOC_HDR h INNER JOIN PS_DOC_HDR_TOT t ON h.[DOC_ID] = t.[DOC_ID]
# Lines: uses PRC for price and UNIT_COST for cost (discovered in PS_DOC_LIN).
CP_OPEN_DOC_LINES_QUERY=SELECT RTRIM(LTRIM(DOC_ID)) AS doc_ref, LIN_SEQ_NO AS lin_seq_no, RTRIM(LTRIM(ITEM_NO)) AS sku, RTRIM(LTRIM(ITEM_NO)) AS counterpoint_item_key, QTY_ORD AS quantity, PRC AS unit_price, UNIT_COST AS unit_cost, CAST(NULL AS NVARCHAR(255)) AS description FROM PS_DOC_LIN WHERE DOC_ID IN (SELECT DOC_ID FROM PS_DOC_HDR)
CP_OPEN_DOC_PMT_QUERY=SELECT RTRIM(LTRIM(DOC_ID)) AS doc_ref, RTRIM(LTRIM(PAY_COD)) AS pmt_typ, AMT AS amount, CAST(NULL AS NVARCHAR(32)) AS gift_cert_no FROM PS_DOC_PMT WHERE DOC_ID IN (SELECT DOC_ID FROM PS_DOC_HDR)

# --- Vendor item cross-ref (PO_VEND_ITEM → vendor_supplier_item; needs migration 89 + vendors + catalog variants) ---
# Cost column: UNIT_COST, VEND_COST, etc. per discover/SSMS (one column name only). Rows limited to the same “active” IM_ITEM set as catalog.
SYNC_VENDOR_ITEMS=1
CP_VEND_ITEM_QUERY=SELECT RTRIM(LTRIM(vi.VEND_NO)) AS vend_no, RTRIM(LTRIM(vi.ITEM_NO)) AS item_no, RTRIM(LTRIM(vi.VEND_ITEM_NO)) AS vend_item_no, vi.UNIT_COST AS vend_cost FROM PO_VEND_ITEM vi WHERE EXISTS (SELECT 1 FROM IM_ITEM i WHERE i.ITEM_NO = vi.ITEM_NO AND RTRIM(LTRIM(i.ITEM_NO)) <> N'' AND (EXISTS (SELECT 1 FROM IM_INV inv2 WHERE inv2.ITEM_NO = i.ITEM_NO AND inv2.LOC_ID = N'MAIN' AND CAST(inv2.QTY_ON_HND AS INT) <> 0) OR EXISTS (SELECT 1 FROM IM_INV_CELL g WHERE g.ITEM_NO = i.ITEM_NO AND CAST(g.QTY_ON_HND AS INT) <> 0) OR RTRIM(LTRIM(i.ITEM_NO)) IN (SELECT DISTINCT RTRIM(LTRIM(l.ITEM_NO)) FROM PS_TKT_HIST_LIN l INNER JOIN PS_TKT_HIST h ON h.TKT_NO = l.TKT_NO WHERE h.DOC_TYP = N'T' AND h.TKT_DT >= '__CP_IMPORT_SINCE__'))) ORDER BY vi.VEND_NO, vi.ITEM_NO
