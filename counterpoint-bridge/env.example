
ROS_BASE_URL=http://YOUR_ROS_SERVER_IP:3000
COUNTERPOINT_SYNC_TOKEN=change-me-long-random

SQL_CONNECTION_STRING=Server=RMSSVR;Database=Riverside;User Id=ros_cp_login;Password=change-me;Encrypt=true;TrustServerCertificate=true

BRIDGE_CONTROL_HOST=0.0.0.0
BRIDGE_CONTROL_PORT=3002

RUN_ONCE=0
WAIT_AFTER_RUN_ONCE=0
POLL_INTERVAL_MS=15000
BATCH_SIZE=200

CP_IMPORT_SINCE=2018-01-01
CURSOR_STATE_FILE=./.counterpoint-bridge-state.json

SYNC_STAFF=1
CP_USERS_QUERY=SELECT RTRIM(LTRIM(USR_ID)) AS usr_id, RTRIM(LTRIM(NAM)) AS nam, RTRIM(LTRIM(EMAIL_ADRS_1)) AS email_adrs, RTRIM(LTRIM(SEC_COD)) AS usr_grp_id FROM SY_USR ORDER BY USR_ID
CP_SALES_REPS_QUERY=
CP_BUYERS_QUERY=

SYNC_VENDORS=1

SYNC_CUSTOMERS=1
CP_CUSTOMERS_QUERY=SELECT RTRIM(LTRIM(CAST(c.CUST_NO AS NVARCHAR(64)))) AS cust_no, RTRIM(LTRIM(c.FST_NAM)) AS first_name, RTRIM(LTRIM(c.LST_NAM)) AS last_name, RTRIM(LTRIM(c.NAM)) AS full_name, RTRIM(LTRIM(c.EMAIL_ADRS_1)) AS email, RTRIM(LTRIM(c.PHONE_1)) AS phone, RTRIM(LTRIM(c.ADRS_1)) AS address_line1, RTRIM(LTRIM(c.ADRS_2)) AS address_line2, RTRIM(LTRIM(c.CITY)) AS city, RTRIM(LTRIM(c.STATE)) AS state, RTRIM(LTRIM(c.ZIP_COD)) AS postal_code, RTRIM(LTRIM(c.CUST_TYP)) AS cust_typ, c.LOY_PTS_BAL AS pts_bal, RTRIM(LTRIM(c.SLS_REP)) AS sls_rep FROM AR_CUST c ORDER BY c.CUST_NO

SYNC_CUSTOMER_NOTES=1
CP_CUSTOMER_NOTES_QUERY=SELECT RTRIM(LTRIM(CUST_NO)) AS cust_no, CAST(NOTE_ID AS NVARCHAR(64)) AS note_id, CONVERT(varchar, NOTE_DAT, 126) + 'Z' AS note_date, NOTE_TXT AS note_text, RTRIM(LTRIM(USR_ID)) AS usr_id FROM AR_CUST_NOTE WHERE NOTE_DAT >= '__CP_IMPORT_SINCE__' ORDER BY CUST_NO, NOTE_ID

SYNC_INVENTORY=1
CP_INVENTORY_QUERY=SELECT RTRIM(LTRIM(i.ITEM_NO)) AS sku, CAST(i.QTY_ON_HND AS INT) AS stock_on_hand, RTRIM(LTRIM(i.ITEM_NO)) AS counterpoint_item_key, i.LST_COST AS last_cost FROM IM_INV i WHERE i.ITEM_NO IS NOT NULL AND i.LOC_ID = 'MAIN' AND NOT EXISTS (SELECT 1 FROM IM_INV_CELL c WHERE c.ITEM_NO = i.ITEM_NO AND c.LOC_ID = i.LOC_ID) UNION ALL SELECT CONCAT(RTRIM(LTRIM(c.ITEM_NO)), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_1_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_2_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_3_UPR))), N'')) AS sku, CAST(c.QTY_ON_HND AS INT) AS stock_on_hand, CONCAT(RTRIM(LTRIM(c.ITEM_NO)), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_1_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_2_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_3_UPR))), N'')) AS counterpoint_item_key, inv.LST_COST AS last_cost FROM IM_INV_CELL c LEFT JOIN IM_INV inv ON inv.ITEM_NO = c.ITEM_NO AND inv.LOC_ID = c.LOC_ID WHERE c.LOC_ID = 'MAIN' AND EXISTS (SELECT 1 FROM IM_ITEM i WHERE i.ITEM_NO = c.ITEM_NO AND RTRIM(LTRIM(i.ITEM_NO)) <> N'')

SYNC_CATEGORY_MASTERS=1
CP_CATEGORY_MASTERS_QUERY=SELECT DISTINCT RTRIM(LTRIM(i.CATEG_COD)) AS cp_category, RTRIM(LTRIM(i.CATEG_COD)) AS display_name FROM IM_ITEM i WHERE RTRIM(LTRIM(i.ITEM_NO)) <> N'' AND NULLIF(RTRIM(LTRIM(i.CATEG_COD)), N'') IS NOT NULL ORDER BY cp_category

SYNC_CATALOG=1
CP_CATALOG_QUERY=SELECT RTRIM(LTRIM(i.ITEM_NO)) AS item_no, RTRIM(LTRIM(i.DESCR)) AS descr, i.LONG_DESCR AS long_descr, RTRIM(LTRIM(i.CATEG_COD)) AS categ_cod, RTRIM(LTRIM(i.VEND_NO)) AS vend_no, CASE WHEN EXISTS (SELECT 1 FROM IM_INV_CELL g WHERE g.ITEM_NO = i.ITEM_NO) THEN 'Y' ELSE 'N' END AS is_grd, p.PRC_1 AS prc_1, p.PRC_2 AS prc_2, p.PRC_3 AS prc_3, inv.LST_COST AS lst_cost, b.BARCOD AS barcode FROM IM_ITEM i LEFT JOIN IM_PRC p ON p.ITEM_NO = i.ITEM_NO LEFT JOIN IM_INV inv ON inv.ITEM_NO = i.ITEM_NO AND inv.LOC_ID = 'MAIN' OUTER APPLY (SELECT TOP 1 bx.BARCOD FROM IM_BARCOD bx WHERE bx.ITEM_NO = i.ITEM_NO ORDER BY bx.BARCOD) b WHERE RTRIM(LTRIM(i.ITEM_NO)) <> N'' ORDER BY i.ITEM_NO
CP_CATALOG_CELLS_QUERY=SELECT RTRIM(LTRIM(c.ITEM_NO)) AS parent_item_no, CONCAT(RTRIM(LTRIM(c.ITEM_NO)), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_1_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_2_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_3_UPR))), N'')) AS counterpoint_item_key, CONCAT(RTRIM(LTRIM(c.ITEM_NO)), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_1_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_2_UPR))), N''), N'|', ISNULL(RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_3_UPR))), N'')) AS sku, (RTRIM(LTRIM(ISNULL(CONVERT(NVARCHAR(80), c.DIM_1_UPR), N''))) + CASE WHEN c.DIM_2_UPR IS NOT NULL THEN N' / ' + RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_2_UPR))) ELSE N'' END + CASE WHEN c.DIM_3_UPR IS NOT NULL THEN N' / ' + RTRIM(LTRIM(CONVERT(NVARCHAR(80), c.DIM_3_UPR))) ELSE N'' END) AS variation_label, CAST(c.QTY_ON_HND AS INT) AS stock_on_hand, CAST(c.MIN_QTY AS INT) AS min_qty, p.PRC_1 AS retail_price, p.PRC_2 AS prc_2, p.PRC_3 AS prc_3, inv.LST_COST AS unit_cost, CAST(NULL AS NVARCHAR(50)) AS barcode FROM IM_INV_CELL c LEFT JOIN IM_PRC p ON p.ITEM_NO = c.ITEM_NO LEFT JOIN IM_INV inv ON inv.ITEM_NO = c.ITEM_NO AND inv.LOC_ID = c.LOC_ID WHERE c.LOC_ID = 'MAIN' AND EXISTS (SELECT 1 FROM IM_ITEM i WHERE i.ITEM_NO = c.ITEM_NO AND RTRIM(LTRIM(i.ITEM_NO)) <> N'')

SYNC_GIFT_CARDS=1
CP_GIFT_CARDS_QUERY=SELECT RTRIM(LTRIM(GFC_NO)) AS cert_no, CAST(ISNULL(CURR_AMT, 0) AS DECIMAL(18,2)) AS balance FROM SY_GFC WHERE ISNULL(CURR_AMT, 0) > 0
CP_GFC_HIST_QUERY=
CP_TICKET_GIFT_QUERY=

SYNC_TICKETS=1
CP_TICKETS_QUERY=SELECT RTRIM(LTRIM(h.[TKT_NO])) AS ticket_ref, RTRIM(LTRIM(h.[CUST_NO])) AS cust_no, CONVERT(varchar, h.[TKT_DT], 126) + 'Z' AS booked_at, h.[TOT] AS total_price, h.[TOT] AS amount_paid, RTRIM(LTRIM(h.[USR_ID])) AS usr_id, RTRIM(LTRIM(h.[SLS_REP])) AS sls_rep FROM PS_TKT_HIST h WHERE h.[TKT_TYP] = 'T' AND h.[TKT_DT] >= '__CP_IMPORT_SINCE__' AND EXISTS (SELECT 1 FROM PS_TKT_HIST_LIN l WHERE l.[DOC_ID] = h.[DOC_ID]) ORDER BY h.[TKT_DT], h.[TKT_NO]
CP_TICKET_LINES_QUERY=SELECT RTRIM(LTRIM(h.[TKT_NO])) AS ticket_ref, l.[LIN_SEQ_NO] AS lin_seq_no, RTRIM(LTRIM(l.[ITEM_NO])) AS sku, RTRIM(LTRIM(l.[ITEM_NO])) AS counterpoint_item_key, l.[QTY_SOLD] AS quantity, l.[PRC] AS unit_price, l.[UNIT_COST] AS unit_cost, CAST(NULL AS NVARCHAR(255)) AS description, RTRIM(LTRIM(l.[RET_REAS])) AS reason_code FROM PS_TKT_HIST_LIN l INNER JOIN PS_TKT_HIST h ON h.[DOC_ID] = l.[DOC_ID] WHERE h.[TKT_TYP] = 'T' AND h.[TKT_DT] >= '__CP_IMPORT_SINCE__'
CP_TICKET_CELLS_QUERY=
CP_TICKET_PAYMENTS_QUERY=SELECT RTRIM(LTRIM(h.[TKT_NO])) AS ticket_ref, RTRIM(LTRIM(p.[PAY_COD])) AS pmt_typ, p.[AMT] AS amount, CAST(NULL AS NVARCHAR(32)) AS gift_cert_no FROM PS_TKT_HIST_PMT p INNER JOIN PS_TKT_HIST h ON h.[DOC_ID] = p.[DOC_ID] WHERE h.[TKT_TYP] = 'T' AND h.[TKT_DT] >= '__CP_IMPORT_SINCE__' AND EXISTS (SELECT 1 FROM PS_TKT_HIST_LIN l WHERE l.[DOC_ID] = h.[DOC_ID])

SYNC_TICKET_NOTES=1
CP_TICKET_NOTES_QUERY=SELECT RTRIM(LTRIM(h.[TKT_NO])) AS ticket_ref, n.[NOTE] AS note FROM PS_TKT_HIST_NOTE n INNER JOIN PS_TKT_HIST h ON n.[DOC_ID] = h.[DOC_ID] WHERE h.[TKT_TYP] = 'T' AND h.[TKT_DT] >= '__CP_IMPORT_SINCE__' AND EXISTS (SELECT 1 FROM PS_TKT_HIST_LIN l WHERE l.[DOC_ID] = h.[DOC_ID])

SYNC_LOYALTY_HIST=0
CP_LOYALTY_HIST_QUERY=

SYNC_RECEIVING_HISTORY=1
CP_RECEIVING_HISTORY_QUERY=SELECT RTRIM(LTRIM(VEND_NO)) AS vend_no, RTRIM(LTRIM(ITEM_NO)) AS item_no, CONVERT(varchar, RECVR_DAT, 126) + 'Z' AS recv_dat, COST AS unit_cost, QTY_RECVD AS qty_recv, RTRIM(LTRIM(PO_NO)) AS po_no, RTRIM(LTRIM(RECVR_NO)) AS recv_no FROM PO_RECVR_HIST WHERE RECVR_DAT >= '__CP_IMPORT_SINCE__' ORDER BY RECVR_DAT, RECVR_NO

SYNC_STORE_CREDIT_OPENING=1
CP_CUSTOMER_STORE_CREDIT_EXISTS=SELECT 1 FROM SY_STC sc WHERE RTRIM(LTRIM(CAST(sc.ORIG_CUST_NO AS NVARCHAR(64)))) = RTRIM(LTRIM(CAST(c.CUST_NO AS NVARCHAR(64)))) AND CAST(ISNULL(sc.CURR_AMT, 0) AS DECIMAL(18,2)) > 0
CP_STORE_CREDIT_QUERY=SELECT RTRIM(LTRIM(CAST(ORIG_CUST_NO AS NVARCHAR(64)))) AS cust_no, CAST(ISNULL(CURR_AMT, 0) AS DECIMAL(18,2)) AS balance FROM SY_STC WHERE CAST(ISNULL(CURR_AMT, 0) AS DECIMAL(18,2)) > 0 ORDER BY ORIG_CUST_NO

SYNC_OPEN_DOCS=1
CP_OPEN_DOCS_QUERY=SELECT RTRIM(LTRIM(h.[DOC_ID])) AS doc_ref, RTRIM(LTRIM(h.[CUST_NO])) AS cust_no, CONVERT(varchar, h.[TKT_DT], 126) + 'Z' AS booked_at, RTRIM(LTRIM(h.[USR_ID])) AS usr_id, RTRIM(LTRIM(h.[SLS_REP])) AS sls_rep, RTRIM(LTRIM(h.[DOC_TYP])) AS doc_typ, t.[TOT] AS total_price, t.[TOT_TND] AS amount_paid FROM PS_DOC_HDR h INNER JOIN PS_DOC_HDR_TOT t ON h.[DOC_ID] = t.[DOC_ID]
CP_OPEN_DOC_LINES_QUERY=SELECT RTRIM(LTRIM(DOC_ID)) AS doc_ref, LIN_SEQ_NO AS lin_seq_no, RTRIM(LTRIM(ITEM_NO)) AS sku, RTRIM(LTRIM(ITEM_NO)) AS counterpoint_item_key, QTY_ORD AS quantity, PRC AS unit_price, UNIT_COST AS unit_cost, CAST(NULL AS NVARCHAR(255)) AS description FROM PS_DOC_LIN
CP_OPEN_DOC_PMT_QUERY=SELECT RTRIM(LTRIM(DOC_ID)) AS doc_ref, RTRIM(LTRIM(PAY_COD)) AS pmt_typ, AMT AS amount, CAST(NULL AS NVARCHAR(32)) AS gift_cert_no FROM PS_DOC_PMT

SYNC_VENDOR_ITEMS=1
CP_VEND_ITEM_QUERY=SELECT RTRIM(LTRIM(vi.VEND_NO)) AS vend_no, RTRIM(LTRIM(vi.ITEM_NO)) AS item_no, RTRIM(LTRIM(vi.VEND_ITEM_NO)) AS vend_item_no, vi.UNIT_COST AS vend_cost FROM PO_VEND_ITEM vi WHERE EXISTS (SELECT 1 FROM IM_ITEM i WHERE i.ITEM_NO = vi.ITEM_NO AND RTRIM(LTRIM(i.ITEM_NO)) <> N'') ORDER BY vi.VEND_NO, vi.ITEM_NO
