# Riverside Counterpoint Sync Bridge
# Normal setup stores only these connection settings.
# NCR Counterpoint POS v8.4 SQL mappings are generated at runtime from INFORMATION_SCHEMA.

SQL_CONNECTION_STRING=

# Go-live workflow: Bridge extracts raw Counterpoint data and sends it directly
# to the Main Hub ROS intake. ROS owns proof, exceptions, duplicate review,
# and final sign-off.
COUNTERPOINT_BRIDGE_TARGET_MODE=ros_import_first
ROS_BASE_URL=http://<MAIN_HUB_LAN_IP>:3000

# Normal setup does not use manual CP_* query overrides. The bridge probes
# the live v8.4 schema and builds extraction SQL at runtime.
