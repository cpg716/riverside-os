# Riverside Counterpoint Sync Bridge
# Normal setup stores only these connection settings.
# NCR Counterpoint POS v8.4 SQL mappings are generated at runtime from INFORMATION_SCHEMA.

SQL_CONNECTION_STRING=

# Preferred transition workflow: Bridge extracts raw Counterpoint data and sends it
# to the Main Hub Counterpoint SYNC Workbench. ROS imports later from approved
# Workbench JSON packages.
COUNTERPOINT_BRIDGE_TARGET_MODE=sync_workbench
COUNTERPOINT_SYNC_WORKBENCH_URL=http://127.0.0.1:3015
# Optional. Leave blank unless the Workbench was deliberately configured to require a token.
COUNTERPOINT_SYNC_WORKBENCH_TOKEN=

# Compatibility-only direct ROS target. Leave these blank for normal Bridge -> SYNC operation.
ROS_BASE_URL=http://127.0.0.1:3000
COUNTERPOINT_SYNC_TOKEN=

# Optional expert-only overrides:
# CP_SQL_ENV_OVERRIDES=1 enables older CP_*_QUERY overrides in this file.
# Leave it unset for the supported v8.4 schema-probe path.
