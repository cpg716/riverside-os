# Riverside OS API (HTTPS recommended in production).
# If the bridge runs on a different PC than ROS, use the ROS machine IP, e.g. http://192.168.1.50:3000
ROS_BASE_URL=http://127.0.0.1:3000
# Must match server COUNTERPOINT_SYNC_TOKEN (restart `cargo run` after changing server .env)
COUNTERPOINT_SYNC_TOKEN=change-me-long-random

# SQL Server (Counterpoint). Always set Database= to the company DB you use in SSMS (not master).
# Example:
# SQL_CONNECTION_STRING=Server=localhost\\RMSSVR;Database=Riverside;User Id=ros_cp_login;Password=secret;Encrypt=true;TrustServerCertificate=true
SQL_CONNECTION_STRING=

# Poll interval (milliseconds)
POLL_INTERVAL_MS=15000
BATCH_SIZE=200

# Optional: path to JSON file storing last cursor (cust_no / sku) per entity
CURSOR_STATE_FILE=./.counterpoint-bridge-state.json

# --- Customers ---
# Set to 0 to disable customer sync loop
SYNC_CUSTOMERS=1
# Default: NCR-style AR customer + address view (use SSMS: SELECT TOP 5 * FROM dbo.VI_AR_CUST_WITH_ADDRESS to confirm columns).
# Required alias: cust_no. Optional: first_name, last_name, full_name, company_name, email, phone, address_line*, city, state, postal_code.
CP_CUSTOMERS_QUERY=SELECT RTRIM(LTRIM(CAST(CUST_NO AS NVARCHAR(64)))) AS cust_no, RTRIM(LTRIM(NAM)) AS full_name, RTRIM(LTRIM(EMAIL_ADRS)) AS email, RTRIM(LTRIM(CONT_1)) AS phone, RTRIM(LTRIM(ADRS_1)) AS address_line1, RTRIM(LTRIM(CITY)) AS city, RTRIM(LTRIM(STATE)) AS state, RTRIM(LTRIM(ZIP_COD)) AS postal_code FROM dbo.VI_AR_CUST_WITH_ADDRESS ORDER BY CUST_NO
# If the view is missing or column names differ, try the master table (often FST_NAM, LST_NAM; address may use other column names — check SSMS):
# CP_CUSTOMERS_QUERY=SELECT RTRIM(LTRIM(CAST(CUST_NO AS NVARCHAR(64)))) AS cust_no, RTRIM(LTRIM(ISNULL(FST_NAM,''))) AS first_name, RTRIM(LTRIM(ISNULL(LST_NAM,''))) AS last_name, RTRIM(LTRIM(CASE WHEN NULLIF(LTRIM(RTRIM(ISNULL(NAM,''))),'') IS NOT NULL THEN LTRIM(RTRIM(NAM)) ELSE LTRIM(RTRIM(CONCAT(RTRIM(LTRIM(ISNULL(FST_NAM,''))),' ',RTRIM(LTRIM(ISNULL(LST_NAM,'')))))) END)) AS full_name, RTRIM(LTRIM(EMAIL_ADRS)) AS email, RTRIM(LTRIM(CONT_1)) AS phone FROM dbo.AR_CUST ORDER BY CUST_NO

# --- Inventory (optional) ---
SYNC_INVENTORY=0
# Example only — replace with a valid item/qty view for your site.
CP_INVENTORY_QUERY=SELECT RTRIM(LTRIM(ITEM_NO)) AS sku, CAST(QTY_ON_HND AS INT) AS stock_on_hand, RTRIM(LTRIM(ITEM_NO)) AS counterpoint_item_key FROM IM_ITEM WHERE ITEM_NO IS NOT NULL
