# Counterpoint SYNC Workbench
# Runs on the Main Hub PC. Bridge posts raw batches here; ROS pulls approved JSON packages.

COUNTERPOINT_SYNC_WORKBENCH_HOST=127.0.0.1
COUNTERPOINT_SYNC_WORKBENCH_PORT=3015
COUNTERPOINT_SYNC_WORKBENCH_URL=http://127.0.0.1:3015
COUNTERPOINT_SYNC_WORKBENCH_TOKEN=change-me-long-random
COUNTERPOINT_SYNC_WORKBENCH_STORE=./data/sync-workbench-store.json
COUNTERPOINT_SYNC_WORKBENCH_DB=./data/sync-workbench-store.sqlite
